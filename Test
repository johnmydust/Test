
    - name: Gather across all namespaces
      k8s_info:
        api_version: operators.coreos.com/v1alpha1
        kind: ClusterServiceVersion
        namespace: all
      register: all_csvs

    - name: Filter 
      set_fact:
        cfs_csvs: >-
          {{ all_csvs.resources 
             | selectattr('spec.displayName', 'defined') 
             | selectattr('spec.displayName', 'search', '') 
             | list }}

    - name: Write CFS versions to a file on the Ansible controller
      delegate_to: localhost
      copy:
        dest: /tmp/cfs_report.txt
        content: |
          {% for cfs in cfs_csvs %}
          Name: {{ cfs.metadata.name }}
          Namespace: {{ cfs.metadata.namespace }}
          Version: {{ cfs.spec.version | default('N/A') }}
          -----------------------------------------------------
          {% endfor %}
