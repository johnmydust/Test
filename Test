for item in results:
            full_path = f"{item['repo']}/{item['path']}"
            stats = item.get('stats', [{}])[0] if 'stats' in item else item.get('stat', {})
            last_download = stats.get('downloaded')
            
            # Store original timestamp for sorting
            if last_download:
                dt = datetime.fromisoformat(last_download.replace('Z', '+00:00'))
            else:
                dt = datetime.max  # This will put "Never" at the end
                
            csv_data.append([full_path, format_timestamp(last_download), dt])

        # Sort by date (oldest first), and remove sorting timestamp before writing
        sorted_data = sorted(csv_data, key=lambda x: x[2])
        sorted_data = [[row[0], row[1]] for row in sorted_data]  # Remove sorting timestamp

        try:
            with open('docker_pulls.csv', 'w', newline='', encoding='utf-8') as f:
                writer = csv.writer(f)
                writer.writerow(['Path', 'Last Downloaded'])
                writer.writerows(sorted_data)
            print("CSV file created successfully")
        except Exception as e:
            print(f"Error writing CSV file: {str(e)}")
