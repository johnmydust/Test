- name: Get NFS server pod name
      kubernetes.core.k8s_info:
        api_version: v1
        kind: Pod
        namespace: default
        label_selectors:
          - app=nfsserver
      register: nfs_pod_info

    - name: Fail if no NFS server pod found
      fail:
        msg: "No NFS server pod found with label app=nfsserver."
      when: nfs_pod_info.resources | length == 0

    - name: Create /NFSV4/data directory inside the NFS server container
      kubernetes.core.k8s_exec:
        namespace: default
        pod: "{{ nfs_pod_info.resources[0].metadata.name }}"
        container: nfsserver
        command: "mkdir -p /NFSV4/data"
      register: mkdir_output
      changed_when: "'created' in mkdir_output.stdout"
